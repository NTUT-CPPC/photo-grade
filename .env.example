NODE_ENV=production
PORT=8080
APP_BASE_URL=http://localhost:8080

DATABASE_URL=postgresql://photo_grade:photo_grade@postgres:5432/photo_grade
REDIS_URL=redis://redis:6379
DATA_DIR=/data

AUTH_MODE=basic
HOST_USERNAME=host
HOST_PASSWORD=change-me-host
SCORE_USERNAME=score
SCORE_PASSWORD=change-me-score
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin

GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=/data/secrets/google-service-account.json

MAX_IMPORT_FILE_MB=50
MAX_MEDIA_FILE_MB=200
SOCKET_CORS_ORIGIN=
