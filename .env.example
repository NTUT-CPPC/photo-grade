NODE_ENV=production
PORT=8080
APP_BASE_URL=http://localhost:8080
PUBLIC_ENTRY_URL=http://localhost:8080
APP_IMAGE=ghcr.io/ntut-cppc/photo-grade:latest
WORKER_IMAGE=ghcr.io/ntut-cppc/photo-grade:latest

POSTGRES_PASSWORD=photo_grade
DATABASE_URL=postgresql://photo_grade:photo_grade@postgres:5432/photo_grade?schema=public
REDIS_URL=redis://redis:6379
DATA_DIR=/data

# Auth: basic | oidc
AUTH_MODE=basic

# Basic auth (used when AUTH_MODE=basic)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# Session (required when AUTH_MODE=oidc; backed by REDIS_URL)
SESSION_SECRET=
COOKIE_SECURE=auto

# OIDC (required when AUTH_MODE=oidc)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email
OIDC_POST_LOGOUT_REDIRECT_URI=

GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SHEET_WORKSHEET=Photo Grade Scores
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=/data/secrets/google-service-account.json

MAX_IMPORT_FILE_MB=50
MAX_MEDIA_FILE_MB=200
SOCKET_CORS_ORIGIN=
