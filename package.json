{
  "name": "photo-grade",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Docker-first photo judging system",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @photo-grade/server",
    "dev:web": "npm run dev -w @photo-grade/web",
    "build": "npm run build -w @photo-grade/shared && npm run build -w @photo-grade/server && npm run build -w @photo-grade/web && npm run build -w @photo-grade/worker",
    "start": "npm run start -w @photo-grade/server",
    "worker": "npm run start -w @photo-grade/worker",
    "prisma:generate": "npm run prisma:generate -w @photo-grade/server",
    "db:push": "npm run db:push -w @photo-grade/server",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "license": "MIT"
}
